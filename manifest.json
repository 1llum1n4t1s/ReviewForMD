{
  "manifest_version": 3,
  "name": "いろいろMDコピー",
  "version": "1.0.48",
  "description": "PRレビュー・Teams会議録画(VTT)・Teamsチャットを Markdown / VTT でダウンロードできるChrome拡張機能",
  "browser_specific_settings": {
    "gecko": {
      "id": "review-for-md@1llum1n4t1s.github.io",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "minimum_chrome_version": "121",
  "permissions": ["activeTab", "scripting", "webNavigation", "clipboardWrite"],
  "host_permissions": [
    "https://github.com/*",
    "https://*.github.com/*",
    "https://dev.azure.com/*",
    "https://*.visualstudio.com/*",
    "https://console.aws.amazon.com/*",
    "https://*.console.aws.amazon.com/*",
    "https://*.sharepoint.com/*",
    "https://teams.microsoft.com/*",
    "https://*.teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://*.teams.live.com/*",
    "https://teams.cloud.microsoft/*",
    "https://*.teams.cloud.microsoft/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/service_worker.js",
    "scripts": ["src/service_worker.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/pull/*",
        "https://github.com/*/pulls",
        "https://github.com/*/pulls?*",
        "https://*.github.com/*/pull/*",
        "https://*.github.com/*/pulls",
        "https://*.github.com/*/pulls?*"
      ],
      "js": [
        "src/lib/site_detector.js",
        "src/lib/markdown_builder.js",
        "src/lib/clipboard.js",
        "src/lib/fetch_utils.js",
        "src/extractors/github_extractor.js",
        "src/ui/button_injector.js",
        "src/content_script.js"
      ],
      "css": ["src/ui/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://dev.azure.com/*/_git/*/pullrequest/*",
        "https://dev.azure.com/*/_git/*/pullRequest/*",
        "https://dev.azure.com/*/_git/*/pullrequests",
        "https://dev.azure.com/*/_git/*/pullrequests?*",
        "https://*.visualstudio.com/*/_git/*/pullrequest/*",
        "https://*.visualstudio.com/*/_git/*/pullRequest/*",
        "https://*.visualstudio.com/*/_git/*/pullrequests",
        "https://*.visualstudio.com/*/_git/*/pullrequests?*"
      ],
      "js": [
        "src/lib/site_detector.js",
        "src/lib/markdown_builder.js",
        "src/lib/clipboard.js",
        "src/lib/fetch_utils.js",
        "src/extractors/devops_extractor.js",
        "src/ui/button_injector.js",
        "src/content_script.js"
      ],
      "css": ["src/ui/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://console.aws.amazon.com/codesuite/codecommit/*",
        "https://*.console.aws.amazon.com/codesuite/codecommit/*"
      ],
      "js": [
        "src/lib/site_detector.js",
        "src/lib/markdown_builder.js",
        "src/lib/clipboard.js",
        "src/lib/fetch_utils.js",
        "src/extractors/codecommit_extractor.js",
        "src/ui/button_injector.js",
        "src/content_script.js"
      ],
      "css": ["src/ui/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.sharepoint.com/*/stream.aspx*",
        "https://*.sharepoint.com/*/Stream.aspx*"
      ],
      "js": [
        "src/lib/site_detector.js",
        "src/lib/markdown_builder.js",
        "src/lib/clipboard.js",
        "src/lib/fetch_utils.js",
        "src/extractors/sharepoint_extractor.js",
        "src/ui/button_injector.js",
        "src/content_script.js"
      ],
      "css": ["src/ui/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://teams.cloud.microsoft/*",
        "https://*.teams.cloud.microsoft/*"
      ],
      "js": [
        "src/lib/site_detector.js",
        "src/lib/markdown_builder.js",
        "src/lib/clipboard.js",
        "src/extractors/teams_extractor.js",
        "src/ui/button_injector.js",
        "src/content_script.js"
      ],
      "css": ["src/ui/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject/navigation_hook.js"],
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*",
        "https://dev.azure.com/*",
        "https://*.visualstudio.com/*",
        "https://console.aws.amazon.com/*",
        "https://*.console.aws.amazon.com/*",
        "https://*/*"
      ]
    },
    {
      "resources": ["src/inject/sharepoint_fetch_hook.js"],
      "matches": [
        "https://*.sharepoint.com/*"
      ]
    }
  ]
}
